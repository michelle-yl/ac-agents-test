# Copy to .env and fill in secrets. Single config for SDL lab agents + knowledge RAG.

# --- Secrets (required for live LLM calls) ---
ANTHROPIC_API_KEY=
HF_TOKEN=

# --- Models ---
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
ANTHROPIC_GRADER_MODEL=claude-haiku-4-5
DB_AGENT_MODEL=claude-haiku-4-5
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- SDL integration ---
SDL_INTEGRATION_MODE=live
# SDL_INTEGRATION_MODE=live

DATABASE_URL=postgresql://angie:angie@localhost:5433/angie_monitoring_replica

HERMES_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=
HERMES_MODEL=hermes-agent
# Connect vs read timeouts (seconds). Gateway serializes agent runs; parallel calls need the lock + these limits.
HERMES_CONNECT_TIMEOUT=10
HERMES_READ_TIMEOUT=180
# On Windows + WSL: retry via WSL eth0 IP when localhost:8642 is unreachable.
HERMES_WSL_AUTO=1
WSL_DISTRO=Ubuntu

OPENCLAW_BASE_URL=http://127.0.0.1:18789
# Gateway token (same as gateway.auth.token in openclaw.json). Required for /v1/* in live mode.
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_MODEL=openclaw/default
# On Windows + WSL Docker: auto-retry via WSL eth0 IP when localhost:18789 is unreachable.
OPENCLAW_WSL_AUTO=1
OPENCLAW_WSL_DISTRO=Ubuntu

SAFETY_DOCS_DIR=./corpus/safety
PROCEDURES_DOCS_DIR=./corpus/procedures
ACADEMIC_DOCS_DIR=./corpus/academic

# --- Monitoring watcher (run_monitor.py) ---
# MONITOR_JSON_DIR=../db/seed/data/monitoring
MONITOR_INGEST_INTERVAL_SEC=60
MONITOR_POLL_INTERVAL_SEC=15
MONITOR_CACHE_MAX_AGE_SEC=120

# --- DB fast path (0 LLM for simple status queries) ---
ROUTER_KEYWORD_FIRST=1
DB_FAST_PATH_ENABLED=1
DB_FAST_PATH_MAX_ROWS=100

# --- Knowledge RAG (run_knowledge_cli.py) ---
SEED_URLS=
LOCAL_DOCS_DIR=

# --- Caveman terse output ---
CAVEMAN_ENABLED=1
CAVEMAN_LEVEL=full
